ortrait([diff(x(t),t)=x(t)+y(t),diff(y(t),t)=4*x(t)-2*y(t)],[x(t),y(t)
],t=-0..10,[[x(0)=0,y(0)=0]],x=-5..5,y=-5..5,stepsize=.1);" }}}{EXCHG 
