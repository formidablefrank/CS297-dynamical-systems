"" {TEXT -1 12 "    write as" }}{PARA 0 "" 0 "" {TEXT -1 58 "         \+
  b d theta/ dt + mgL sin (theta) = Gamma, where " }}{PARA 0 "" 0 "" 
{TEXT -1 11 "b = damping" }}{PARA 0 "" 0 "" {TEXT -1 8 "m = mass" }}
{PARA 0 "" 0 "" {TEXT -1 26 "g = gravitational constant" }}{PARA 0 "" 
0 "" {TEXT -1 22 "L = length of pendulum" }}{PARA 0 "" 0 "" {TEXT -1 
22 "Gamma = applied torque" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 
"" 0 "" {TEXT -1 42 "simplifies to (in the case of overdamping)" }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 88 "d theta/d
t = gamma - sin (theta), where gamma = applied torque/ max gravitation
al torque" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 "
