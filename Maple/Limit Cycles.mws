1);" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "> " 0 
"" {MPLTEXT 1 0 114 "DEplot(diff(x(t),t$2)+mu*(x(t)^2-1)*diff(x(t),t$1
