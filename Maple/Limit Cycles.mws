0 "" {TEXT -1 54 "  Try smaller ep. Note resonant forcing term on righ
t." }}{PARA 0 "" 0 "" {TEXT -1 58 "  Fast time= sinusoidal oscillation
s; slow time for decay." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 22 "# Two-timing, T and t." }}}{EXCHG 
{PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "" 0 "" {TEXT 
-1 74 "  d^x/dt^2 + x = -2(A' + A) cos(t) + 2(B' + B) sin(t), even mor
e resonant!" }}{PARA 0 "" 0 "" {TEXT -1 47 "Set coefficients in right \+
hand to zero, we have" }}{PARA 0 "" 0 "" {TEXT -1 36 "   A(T) = exp(-T
), A'(T) = - exp(-T)" }}{PARA 0 "" 0 "" {TEXT -1 23 "   B(T) = 0, B'(T
) = 0." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 22 
"so we have the problem" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 
0 "" {TEXT -1 79 " d^x/dt^2 + x = -2(-exp(-T)+ exp(-T) ) cos(t) + 2(0 \+
+ 0) sin(t), = 0 by design." }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 
8 "" 1 "" {TEXT -1 23 "missing operator or `;`" }}}{EXCHG {PARA 0 "> \+
" 0 "" {MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "
