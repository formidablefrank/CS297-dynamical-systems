,t$2)+diff(x(t),t$1)^3+x(t)=0,x(t),\nt=0..10,[[x(0)=1,D(x)(0)=2]],x=-3
..3,stepsize=.1);" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 38 " say y = dx/
