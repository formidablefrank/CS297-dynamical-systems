losed orbits are impossible in gradient systems" }}}{EXCHG {PARA 0 "" 
0 "" {TEXT -1 16 " gradient system" }}{PARA 0 "" 0 "" {TEXT -1 66 "  d
x/dt = - grad V, where V(x0 is a single-valued scalar function." }}
{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" {TEXT -1 63 "   This i
s called a gradient system with potential function V/ " }}{PARA 0 "" 
0 "" {TEXT -1 0 "" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 46 " Ex. 7.2.2 S
how there are no closed orbits in " }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}
{PARA 0 "" 0 "" {TEXT -1 16 "  dx/dt = sin(y)" }}{PARA 0 "" 0 "" 
{TEXT -1 18 "  dy/dt = x cos(y)" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 
1 0 0 "" }}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 154 "phaseportrait([
diff(x(t),t)=sin(y(t)),diff(y(t),t)=x(t)*cos(y(t))],[x(t),y(t)],t=0..2
0,[[x(0)=2,y(0)=-Pi/2+1/4]],x=-2*Pi..2*Pi,y=-2*Pi..2*Pi,stepsize=.1);
" }}}{EXCHG {PARA 0 "" 0 "" {TEXT -1 0 "" }}}{PARA 0 "" 0 "" {TEXT -1 
133 "This is a gradient system with potential V(x,y) = -x sin(y), and \+
dx/dt = - partial V/ partial x, and dy/dt = - partial V/ partial y. " 
}}{EXCHG {PARA 0 "> " 0 "" {MPLTEXT 1 0 0 "" }}}{EXCHG {PARA 0 "" 0 "
" {TEXT -1 68 " Ex. 7.2.2 This nonlinearly damped oscillator had no pe
riodic orbits" }}{PARA 0 "" 0 "" {TEXT -1 0 "" }}{PARA 0 "" 0 "" 
{TEXT -1 30 " d^2x/ dt^2 + (dx/dt)^3 + x =0" }}{PARA 0 "" 0 "" {TEXT 
