      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<r <= 0, stable fixed point\>\"", ",", " ", 
          "\"\<0 < r < 1, unstable and stable and unstable fixed points\>\"", 
          ",", "\"\<r >= 1, unstable fixed point\>\""}], "}"}], ",", 
        "Below"}], "]"}]}]}], "]"}], ",", " ", 
   RowBox[{"Plot", "[", 
