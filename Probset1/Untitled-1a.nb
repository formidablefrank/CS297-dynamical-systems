Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "r_", "]"}], ":=", 
   RowBox[{
    RowBox[{"r", "*", "x"}], "-", 
    RowBox[{"x", "/", 
     RowBox[{"(", 
      RowBox[{"1", "+", 
       SuperscriptBox["x", "2"]}], ")"}]}]}]}], 
