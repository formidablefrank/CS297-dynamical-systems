Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "r_", "]"}], ":=", 
   RowBox[{
    RowBox[{"r", "*", "x"}], "+", 
    SuperscriptBox["x", "3"], "-", 
    SuperscriptBox["x", "5"]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "2"}], "]"}], ",", 
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "4"}], "]"}], ",", 
       RowBox[{"f", "[", 
        RowBox[{
         RowBox[{"-", "1"}], "/", "8"}], "]"}], ",", 
       RowBox[{"f", "[", "0", "]"}], ",", 
       RowBox[{"f", "[", 
        RowBox[{"1", "/", "8"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1.1"}], ",", "1.1"}], "}"}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<r < -1/4, stable fixed point\>\"", ",", 
          "\"\<r = -1/4, half-stable and stable and half-stable fixed \
points\>\"", ",", " ", 
          "\"\<0 > r > -1/4, stable and unstable and stable and unstable and \
stable fixed points\>\"", ",", " ", 
          "\"\<r = 0, stable and unstable and stable fixed points\>\"", ",", 
          " ", "\"\<r > 0, stable and unstable and stable fixed points\>\""}],
          "}"}], ",", "Below"}], "]"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", "Thinning"}], ",", 
