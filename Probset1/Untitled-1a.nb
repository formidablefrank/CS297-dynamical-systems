 RowBox[{
  RowBox[{
   RowBox[{"r", "[", "x_", "]"}], ":=", 
   RowBox[{"2", 
    RowBox[{
     SuperscriptBox["x", "3"], "/", 
     SuperscriptBox[
      RowBox[{"(", 
       RowBox[{"1", "+", 
        SuperscriptBox["x", "2"]}], ")"}], "2"]}]}]}], ";", 
  RowBox[{
   RowBox[{"k", "[", "x_", "]"}], ":=", 
   RowBox[{"2", 
    RowBox[{
     SuperscriptBox["x", "3"], "/", 
     RowBox[{"(", 
      RowBox[{
       SuperscriptBox["x", "2"], "-", "1"}], ")"}]}]}]}], 
