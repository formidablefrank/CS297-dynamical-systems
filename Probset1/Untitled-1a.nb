Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "r_", "]"}], ":=", 
   RowBox[{"x", "+", 
    RowBox[{"r", "*", 
     RowBox[{"x", "/", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"x", "^", "2"}], "+", "1"}], ")"}]}]}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"f", "[", 
        RowBox[{"-", "1.5"}], "]"}], ",", 
       RowBox[{"f", "[", "0", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", "1"}], ",", "1"}], "}"}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<r <= -1, unstable fixed point\>\"", ",", " ", 
          "\"\<r > 1, unstable and stable and unstable fixed point\>\""}], 
         "}"}], ",", "Below"}], "]"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", "\"\<f[x]\>\""}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"r", "<=", 
             RowBox[{"-", "1"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "Infinity"}], ",", 
            RowBox[{"r", ">", 
             RowBox[{"-", "1"}]}]}], "}"}]}], "}"}], "]"}], ",", 
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "Infinity"}], ",", 
            RowBox[{"r", "<=", 
             RowBox[{"-", "1"}]}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"r", ">", 
             RowBox[{"-", "1"}]}]}], "}"}]}], "}"}], "]"}], ",", 
       SqrtBox[
        RowBox[{
         RowBox[{"-", "1"}], "-", "r"}]], ",", 
       RowBox[{"-", 
        SqrtBox[
         RowBox[{
          RowBox[{"-", "1"}], "-", "r"}]]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"-", "2"}], ",", "0"}], "}"}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<r\>\"", ",", "\"\<x\>\""}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<stable\>\"", ",", "\"\<unstable\>\"", ",", "\"\<unstable\>\"", 
          ",", "\"\<unstable\>\""}], "}"}], ",", "Below"}], "]"}]}], ",", 
     RowBox[{"AspectRatio", "\[Rule]", "1"}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{
       "Thick", ",", " ", "Dashed", ",", " ", "Dashed", ",", " ", "Dashed"}], 
       "}"}]}]}], "]"}]}], "}"}]}], "Input",
