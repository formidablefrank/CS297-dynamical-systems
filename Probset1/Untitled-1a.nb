Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"f", "[", "r_", "]"}], ":=", 
   RowBox[{
    RowBox[{"r", "*", "x"}], "-", 
    RowBox[{"x", "/", 
     RowBox[{"(", 
      RowBox[{"1", "+", "x"}], ")"}]}]}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"{", 
  RowBox[{
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"f", "[", "0.5", "]"}], ",", 
       RowBox[{"f", "[", "1", "]"}], ",", 
       RowBox[{"f", "[", "1.5", "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"x", ",", 
       RowBox[{"-", ".5"}], ",", "1.2"}], "}"}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<r < 1, stable and unstable fixed point\>\"", ",", 
          "\"\<r = 1, half-stable fixed point\>\"", ",", " ", 
          "\"\<r > 1, stable and unstable fixed point\>\""}], "}"}], ",", 
        "Below"}], "]"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"\"\<x\>\"", ",", "\"\<f[x]\>\""}], "}"}]}], ",", 
     RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}], ",", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"r", "<=", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "Infinity"}], ",", 
            RowBox[{"r", ">", "1"}]}], "}"}]}], "}"}], "]"}], ",", 
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"-", "Infinity"}], ",", 
            RowBox[{"r", "<=", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"0", ",", 
            RowBox[{"r", ">", "1"}]}], "}"}]}], "}"}], "]"}], ",", 
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "r"}], ")"}], "/", "r"}], ",", 
            RowBox[{"r", "\[LessEqual]", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"Infinity", ",", 
            RowBox[{"r", ">", "1"}]}], "}"}]}], "}"}], "]"}], ",", 
       RowBox[{"Piecewise", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Infinity", ",", 
            RowBox[{"r", "\[LessEqual]", "1"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{
             RowBox[{"(", 
              RowBox[{"1", "-", "r"}], ")"}], "/", "r"}], ",", 
            RowBox[{"r", ">", "1"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", 
       RowBox[{"-", "5"}], ",", "5"}], "}"}], ",", 
     RowBox[{"Exclusions", "\[Rule]", 
      RowBox[{
       RowBox[{"r", "/", 
        RowBox[{"(", 
         RowBox[{"r", "-", "1"}], ")"}]}], "\[Equal]", "0"}]}], ",", 
     RowBox[{"AxesLabel", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"r", ",", "x"}], "}"}]}], ",", 
     RowBox[{"PlotLegends", "\[Rule]", 
      RowBox[{"Placed", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
         "\"\<stable\>\"", ",", "\"\<unstable\>\"", ",", "\"\<unstable\>\"", 
          ",", "\"\<stable\>\""}], "}"}], ",", "Below"}], "]"}]}], ",", 
     RowBox[{"PlotStyle", "\[Rule]", 
      RowBox[{"{", 
       RowBox[{"Thick", ",", "Dashed", ",", "Dashed", ",", "Thick"}], "}"}]}],
      ",", 
     RowBox[{"AspectRatio", "\[Rule]", "1"}]}], "]"}]}], "}"}]}], "Input",
