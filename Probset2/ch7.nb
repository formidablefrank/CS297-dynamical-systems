Cell[BoxData[
 RowBox[{"G2", "=", 
  RowBox[{"ContourPlot", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"y", "\[Equal]", "0"}], ",", 
      RowBox[{"x", "\[Equal]", 
       RowBox[{"y", "-", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          SuperscriptBox["x", "4"]}], ")"}]}]}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", "2"}], "+", 
        RowBox[{"y", "^", "2"}]}], "\[Equal]", ".1"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"4", 
         RowBox[{"x", "^", "2"}]}], "+", 
        RowBox[{"y", "^", "2"}], "-", 
        RowBox[{"3", "*", "x", "*", "y"}]}], "\[Equal]", "25"}], ",", 
      RowBox[{
       RowBox[{
        RowBox[{"x", "^", "2"}], "+", 
        RowBox[{"2", 
         RowBox[{"y", "^", "2"}]}], "-", 
        RowBox[{"x", "*", "y"}]}], "\[Equal]", "25"}]}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", 
      RowBox[{"-", "10"}], ",", "10"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", 
