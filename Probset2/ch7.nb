Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"f", "[", "a_", "]"}], "[", "x_", "]"}], ":=", 
   RowBox[{
    RowBox[{"a", "*", "x"}], "-", 
    RowBox[{"1.19", " ", 
     RowBox[{"x", "^", "3"}]}]}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"cps", "[", "a_", "]"}], "=", 
   RowBox[{"x", "/.", 
    RowBox[{"Quiet", "[", 
     RowBox[{
      RowBox[{"Solve", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"D", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"f", "[", "a", "]"}], "[", "x", "]"}], ",", "x"}], "]"}], 
         "\[Equal]", "0"}], ",", "x"}], "]"}], ",", 
      RowBox[{"Solve", "::", "ratnz"}]}], "]"}]}]}], 
  ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"criticalOrbits", "[", 
    RowBox[{"a_", ",", "cp_"}], "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", "try", "}"}], ",", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Head", "[", "cp", "]"}], "===", "Real"}], ",", 
       RowBox[{
        RowBox[{"try", "=", 
         RowBox[{"NestWhileList", "[", 
          RowBox[{
           RowBox[{"f", "[", "a", "]"}], ",", "cp", ",", 
           RowBox[{
            RowBox[{
             RowBox[{"Abs", "[", "#", "]"}], "<", "100"}], "&"}], ",", "1", 
           ",", "500"}], "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Abs", "[", 
            RowBox[{"Last", "[", "try", "]"}], "]"}], "\[GreaterEqual]", 
           "100"}], ",", 
          RowBox[{"try", "=", 
           RowBox[{"{", "}"}]}], ",", 
          RowBox[{"try", "=", 
           RowBox[{"Drop", "[", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{"{", 
                RowBox[{"a", ",", "#"}], "}"}], "&"}], "/@", "try"}], ",", 
             "100"}], "]"}]}]}], "]"}]}], ",", 
       RowBox[{"{", "}"}]}], "]"}]}], "]"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"points", "[", "k_", "]"}], ":=", 
   RowBox[{"Partition", "[", 
    RowBox[{
     RowBox[{"Flatten", "[", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"criticalOrbits", "[", 
         RowBox[{"a", ",", 
          RowBox[{
           RowBox[{"cps", "[", "a", "]"}], "[", 
           RowBox[{"[", "k", "]"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"a", ",", 
          RowBox[{"-", "2"}], ",", "4", ",", "0.002"}], "}"}]}], "]"}], "]"}],
      ",", "2"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
 RowBox[{"Graphics", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"Opacity", "[", "0.02", "]"}], ",", 
     RowBox[{"PointSize", "[", "0.002", "]"}], ",", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"ColorData", "[", 
          RowBox[{"1", ",", "k"}], "]"}], ",", 
         RowBox[{"Point", "[", 
          RowBox[{"points", "[", "k", "]"}], "]"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", "1", ",", 
         RowBox[{"Length", "[", 
          RowBox[{"cps", "[", "a", "]"}], "]"}]}], "}"}]}], "]"}]}], "}"}], 
   ",", 
   RowBox[{"Frame", "\[Rule]", "True"}]}], "]"}]}], "Input",
 CellChangeTimes->{{3.6904612505147676`*^9, 3.690461282960884*^9}}],

